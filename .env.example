# Idraa — operator configuration (evaluation self-hosting)
#
# Copy to .env next to docker-compose.yml. Two INDEPENDENT mechanisms read
# this file once copied:
#   (a) `docker compose` interpolates `${VAR}` references *inside*
#       docker-compose.yml (e.g. the `${SESSION_SECRET:?...}` guard) from
#       this file.
#   (b) the `app` service's `env_file:` entry injects every UNCOMMENTED
#       line in this file directly into the app container's environment.
#
# NOTE: (b) uses the `env_file:` LONG syntax (a `path:`/`required:` mapping,
# not a bare string) — this needs Docker Compose >= 2.24. Older versions fail
# loudly at `docker compose up` rather than silently ignoring the file, so
# there is no silent-misconfiguration risk, but upgrade if you hit that error.
#
# Because of (b): an uncommented line with an EMPTY value (e.g.
# `AUTH_MAX_FAILED_LOGINS=`) injects the literal empty string "" into the
# container — which breaks int-typed Settings fields at boot (pydantic
# cannot parse "" as an int). For that reason every variable below EXCEPT
# SESSION_SECRET/ENVIRONMENT ships commented out with an example value.
# Uncomment only what you are actually setting, with a real value.
#
# Full reference incl. internal tuning knobs: src/idraa/config.py docstrings.

# ── Core ────────────────────────────────────────────────────────────────────
# REQUIRED. Generate: python -c 'import secrets; print(secrets.token_urlsafe(48))'
# compose refuses to start without it; prod requires 32+ chars.
SESSION_SECRET=

# dev | prod | test. prod turns on secret + WebAuthn + MFA-key hardening at
# boot (see _check_secret_hardening / _check_webauthn_hardening /
# _check_mfa_key_hardening in src/idraa/config.py).
# Any instance real users reach over a network must set prod — dev also
# disables the Secure cookie flag and exposes /api/docs. test is test-harness
# only (it disables the secret guards) — never use it for a running instance.
ENVIRONMENT=dev

# compose default points at the bundled Postgres service; SQLite also works:
# sqlite+aiosqlite:////data/idraa.db
# NOTE: under docker compose this var is IGNORED — compose pins the bundled db
# service's DSN in docker-compose.yml; it only takes effect for non-compose runs.
#DATABASE_URL=postgresql+asyncpg://idraa:idraa@db:5432/idraa

# ── Reverse proxy ───────────────────────────────────────────────────────────
# If Idraa runs behind a TLS-terminating proxy (required for passkeys), set
# this to your REVERSE PROXY'S IP address(es) (comma-separated) so uvicorn
# trusts its X-Forwarded-Proto/Host/For headers and generates absolute URLs
# with https:// + your public host.
#
# Do NOT set this to "*" unless you have verified no other path reaches this
# port directly: "*" trusts the LEFTMOST entry in X-Forwarded-For, but a
# standard proxy APPENDS to that header rather than replacing it — so any
# client that can reach the app port directly can prepend a forged "client
# IP" that the app will then record as trusted/authoritative.
#
# The shipped docker-compose.yml publishes port 8000 on ALL interfaces
# (0.0.0.0), not just loopback. If this host is reachable from the internet,
# firewall port 8000 (or bind it to loopback) so it is reachable ONLY via
# your reverse proxy.
#
# If your proxy runs on the SAME host as docker compose (e.g. nginx on the
# host, reaching the container via the published port rather than the
# compose network), the connection crosses the Docker bridge — the app
# container sees the source IP as the bridge GATEWAY (e.g. 172.x.0.1), not
# the proxy's own LAN/host IP. If headers seem to be ignored even though
# FORWARDED_ALLOW_IPS is set, check the actual peer IP the app is seeing
# (docker logs, or a debug 400) and trust that address, not the proxy's
# LAN IP.
#FORWARDED_ALLOW_IPS=<your-reverse-proxy-ip>

# ── Auth / MFA ──────────────────────────────────────────────────────────────
# required (default): every user must enroll a second factor at first login.
# optional: sensible for throwaway evaluation instances.
#AUTH_MFA_POLICY=required

# Encrypts stored TOTP secrets at rest. Generate like SESSION_SECRET.
# dev/test: unset falls back to deriving the key from SESSION_SECRET (see
# services/mfa_crypto.py:32) — convenient, but rotating SESSION_SECRET then
# permanently bricks every already-stored TOTP secret (key-separation
# violation). Set a distinct, stable value before any real user enrolls TOTP.
# prod: REFUSES TO BOOT without this set (see config.py's
# _check_mfa_key_hardening) — there is no fallback allowed in prod.
#MFA_ENCRYPTION_KEY=

# Login throttle: failures before lockout (0 disables) / lockout seconds.
#AUTH_MAX_FAILED_LOGINS=5
#AUTH_LOCKOUT_SECONDS=900

# Step-up ("sudo") freshness for sensitive actions, seconds (0 disables).
#AUTH_STEP_UP_MAX_AGE_SECONDS=600

# ── Passkeys (WebAuthn) ─────────────────────────────────────────────────────
# RP-ID = your registrable domain (no scheme/port). Passkeys are PERMANENTLY
# bound to it — set it correctly before the first user enrolls. In prod the
# app refuses to boot on the localhost default.
#WEBAUTHN_RP_ID=localhost
#WEBAUTHN_ORIGINS=http://localhost:8000
#WEBAUTHN_RP_NAME=Idraa

# ── Simulation envelope ─────────────────────────────────────────────────────
#MC_ITERATIONS_DEFAULT=10000
#MC_ITERATIONS_MAX=1000000
#HIGH_FIDELITY_ITERATIONS_THRESHOLD=250000
#MAX_CONCURRENT_HIGH_FIDELITY_RUNS=2

# ── Retention / disk ────────────────────────────────────────────────────────
# 0 disables the sweeps. Full per-iteration sample arrays are the disk hog —
# purging keeps runs + summaries, drops re-derivable chart detail.
#RETENTION_SAMPLE_PURGE_DAYS=0
#RETENTION_RUN_DELETE_DAYS=0
#RETENTION_SWEEP_INTERVAL_HOURS=6
#MIN_FREE_DISK_BYTES=300000000

# ── Export rate limiting ────────────────────────────────────────────────────
#EXPORT_RATE_LIMIT_COUNT=30
#EXPORT_RATE_LIMIT_WINDOW_SECONDS=300
