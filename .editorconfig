# EditorConfig — cross-platform editor consistency
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Web/data formats — 2-space convention
[*.{yml,yaml,json,html,css,js,ts,jsx,tsx,md,j2,jinja,jinja2}]
indent_size = 2

# Python — 4 spaces (PEP 8)
[*.py]
indent_size = 4
max_line_length = 100

# Tab-required formats
[Makefile]
indent_style = tab

[*.go]
indent_style = tab

# Windows-only scripts — CRLF
[*.{bat,cmd,ps1}]
end_of_line = crlf

# Notebooks — don't trim trailing whitespace (breaks JSON)
[*.ipynb]
trim_trailing_whitespace = false
insert_final_newline = false
